# Production room server. TLS is normally terminated by the hosting platform.
HOST=0.0.0.0
PORT=8787
WS_PATH=/ws
HEALTH_LIVE_PATH=/health/live
HEALTH_READY_PATH=/health/ready
ALLOWED_ORIGINS=https://your-web-debug-console.example
ALLOW_MISSING_ORIGIN=true
MAX_PAYLOAD_BYTES=65536
SHUTDOWN_GRACE_MS=5000
HEARTBEAT_INTERVAL_MS=10000
CONNECTION_TIMEOUT_MS=30000
DEADLINE_POLL_INTERVAL_MS=250

# Public mobile build configuration. Never put credentials or secrets here.
EXPO_PUBLIC_ROOM_SERVER_MODE=production
EXPO_PUBLIC_ROOM_SERVER_URL=wss://your-room-server.example/ws
